# Настройки подключения к БД (Для локального запуска используйте localhost)
# При деплое на Railway вставьте сюда PUBLIC_URL из панели Railway
DATABASE_URL="postgresql://username:password@localhost:5432/db_name?schema=public"

# Секретный ключ для авторизации (минимум 32 символа)
JWT_SECRET="your-super-secret-key-change-me-in-production"
JWT_EXPIRES_IN="7d"

# Порты и CORS
PORT=3000
CORS_ORIGIN="http://localhost:3001"